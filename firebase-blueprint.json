{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Information about a shop product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "price", "stock", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Shop customization settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "promptPayQrUrl": { "type": "string" },
        "banner0": { "type": "string" },
        "banner1": { "type": "string" },
        "banner2": { "type": "string" },
        "lineLink": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["bank_transfer", "promptpay"] },
        "slipUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "packaging", "shipped", "cancelled", "delivered"] },
        "trackingNumber": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "customerName", "customerPhone", "customerAddress", "total", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "points": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "Review": {
      "title": "Review",
      "description": "Feedback reviews on products left by shoppers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["productId", "rating", "comment"]
    },
    "PointTransaction": {
      "title": "PointTransaction",
      "description": "Log of additions or reductions of user reward points",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "points": { "type": "number" },
        "type": { "type": "string", "enum": ["earn", "use", "admin"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "points", "type"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon logic",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minPurchase": { "type": "number" },
        "usageLimit": { "type": "number" },
        "usageCount": { "type": "number" },
        "isActive": { "type": "boolean" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" }
      },
      "required": ["code", "type", "value"]
    },
    "Slip": {
      "title": "Slip",
      "description": "Individual payment slip records uploaded by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "uid": { "type": "string" },
        "url": { "type": "string" },
        "customerName": { "type": "string" },
        "total": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["orderId", "url"]
    },
    "Stat": {
      "title": "Stat",
      "description": "Global statistics like visitor records",
      "type": "object",
      "properties": {
        "count": { "type": "number" }
      },
      "required": ["count"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Contact form submissions from visitors",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "email", "message"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications regarding their orders or account activity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "orderId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "title", "message", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products in the shop"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories"
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "Global shop configurations"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders made by users"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Protected user demographic details"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Customer feedback on products"
    },
    "/pointTransactions/{txId}": {
      "schema": "PointTransaction",
      "description": "Point transactional history logs"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Promo codes and discounts"
    },
    "/slips/{slipId}": {
      "schema": "Slip",
      "description": "User uploaded payment slips"
    },
    "/stats/{statId}": {
      "schema": "Stat",
      "description": "Metadata for aggregate shop metrics"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Shopper inquiries and contacts"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications for status updates or admin announcements"
    }
  }
}
